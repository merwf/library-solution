@page "/books"
@using Library.Core
@using Library.UI.Services
@inject IBookService BookService
@inject IToastService Toast

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Kitap Yönetim Paneli</h3>
        <button class="btn btn-primary" @onclick="OpenAddModal" disabled="@isBusy">Yeni Kitap Ekle</button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <span>Yükleniyor...</span>
        </div>
    }
    else if (loadError != null)
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>@loadError</span>
            <button class="btn btn-sm btn-outline-danger" @onclick="RefreshList">Tekrar Dene</button>
        </div>
    }
    else if (books == null || !books.Any())
    {
        <div class="alert alert-secondary text-center">Kayıt bulunamadı.</div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Kitap Adı</th>
                    <th>Yazar</th>
                    <th>ISBN</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in books)
                {
                    <tr>
                        <td>@book.Id</td>
                        <td>
                            @if (editingBookId == book.Id)
                            {
                                <input type="text" class="form-control form-control-sm" @bind="editingBook.Title" />
                            }
                            else
                            {
                                @book.Title
                            }
                        </td>
                        <td>
                            @if (editingBookId == book.Id)
                            {
                                <input type="text" class="form-control form-control-sm" @bind="editingBook.Author" />
                            }
                            else
                            {
                                @book.Author
                            }
                        </td>
                        <td>
                            @if (editingBookId == book.Id)
                            {
                                <input type="text" class="form-control form-control-sm" @bind="editingBook.ISBN" />
                            }
                            else
                            {
                                @book.ISBN
                            }
                        </td>
                        <td>
                            <span class="badge @(book.IsAvailable ? "bg-success" : "bg-danger")">
                                @(book.IsAvailable ? "Mevcut" : "Ödünçte")
                            </span>
                        </td>
                        <td>
                            @if (editingBookId == book.Id)
                            {
                                <button class="btn btn-success btn-sm" @onclick="() => SaveRow(book)" disabled="@isBusy">
                                    @(isBusy ? "Kaydediliyor..." : "Kaydet")
                                </button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelEdit" disabled="@isBusy">İptal</button>
                            }
                            else
                            {
                                <button class="btn btn-warning btn-sm" @onclick="() => StartEdit(book)" disabled="@isBusy">Düzenle</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => PromptDelete(book)" disabled="@isBusy">Sil</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- YENİ KİTAP EKLEME MODAL PANELİ -->
@if (showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Kitap Ekle</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <EditForm Model="newBook" OnValidSubmit="HandleAddBook">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Kitap Adı</label>
                            <InputText class="form-control" @bind-Value="newBook.Title" />
                            <ValidationMessage For="() => newBook.Title" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Yazar</label>
                            <InputText class="form-control" @bind-Value="newBook.Author" />
                            <ValidationMessage For="() => newBook.Author" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">ISBN</label>
                            <InputText class="form-control" @bind-Value="newBook.ISBN" />
                            <ValidationMessage For="() => newBook.ISBN" class="text-danger" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddModal" disabled="@isBusy">Vazgeç</button>
                        <button type="submit" class="btn btn-primary" disabled="@isBusy">
                            @(isBusy ? "Ekleniyor..." : "Ekle")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- SİLME ONAY DIALOGU -->
@if (showDeleteDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Kayıt Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"@selectedBookForDelete?.Title"</strong> isimli kitabı sistemden silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete" disabled="@isBusy">Vazgeç</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isBusy">
                        @(isBusy ? "Siliniyor..." : "Evet, Sil")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<BookDto>? books;
    private BookDto newBook = new();
    private BookDto editingBook = new();

    private bool showAddModal = false;
    private bool showDeleteDialog = false;
    private int editingBookId = 0;
    private BookDto? selectedBookForDelete;

    private bool isLoading = true;
    private bool isBusy = false;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshList();
    }

    private async Task RefreshList()
    {
        isLoading = true;
        loadError = null;
        try
        {
            books = await BookService.GetBooksAsync();
        }
        catch (Exception)
        {
            loadError = "Kitaplar yüklenirken bir hata oluştu. Lütfen API bağlantısını kontrol edip tekrar deneyin.";
            books = new List<BookDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenAddModal() { newBook = new(); showAddModal = true; }
    private void CloseAddModal() => showAddModal = false;

    private async Task HandleAddBook()
    {
        isBusy = true;
        try
        {
            var success = await BookService.AddBookAsync(newBook);
            if (success)
            {
                showAddModal = false;
                Toast.ShowSuccess($"\"{newBook.Title}\" başarıyla eklendi.");
                await RefreshList();
            }
            else
            {
                Toast.ShowError("Kitap eklenirken bir hata oluştu.");
            }
        }
        catch (Exception)
        {
            Toast.ShowError("Sunucuya ulaşılamadı. Kitap eklenemedi.");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void StartEdit(BookDto book)
    {
        editingBookId = book.Id;
        editingBook = new BookDto
        {
            Id = book.Id,
            Title = book.Title,
            Author = book.Author,
            ISBN = book.ISBN,
            IsAvailable = book.IsAvailable
        };
    }

    private void CancelEdit() => editingBookId = 0;

    private async Task SaveRow(BookDto originalBook)
    {
        if (string.IsNullOrWhiteSpace(editingBook.Title) || string.IsNullOrWhiteSpace(editingBook.Author) || string.IsNullOrWhiteSpace(editingBook.ISBN))
        {
            Toast.ShowWarning("Lütfen tüm alanları doldurun.");
            return;
        }

        isBusy = true;
        try
        {
            var success = await BookService.UpdateBookAsync(originalBook.Id, editingBook);
            if (success)
            {
                editingBookId = 0;
                Toast.ShowSuccess("Kitap bilgileri güncellendi.");
                await RefreshList();
            }
            else
            {
                Toast.ShowError("Güncelleme sırasında bir hata oluştu.");
            }
        }
        catch (Exception)
        {
            Toast.ShowError("Sunucuya ulaşılamadı. Güncelleme yapılamadı.");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void PromptDelete(BookDto book)
    {
        selectedBookForDelete = book;
        showDeleteDialog = true;
    }

    private void CancelDelete() => showDeleteDialog = false;

    private async Task ConfirmDelete()
    {
        if (selectedBookForDelete == null) return;

        isBusy = true;
        try
        {
            var success = await BookService.DeleteBookAsync(selectedBookForDelete.Id);
            if (success)
            {
                showDeleteDialog = false;
                Toast.ShowSuccess($"\"{selectedBookForDelete.Title}\" silindi.");
                await RefreshList();
            }
            else
            {
                Toast.ShowError("Silme işlemi sırasında bir hata oluştu.");
            }
        }
        catch (Exception)
        {
            Toast.ShowError("Sunucuya ulaşılamadı. Kitap silinemedi.");
        }
        finally
        {
            isBusy = false;
        }
    }
}
