@page "/"
@using Library.UI.Services
@inject IBookService BookService
@inject IMemberService MemberService
@inject IBorrowService BorrowService

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3 border">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold text-primary">Kütüphane Yönetim Sistemi</h1>
            <p class="col-md-8 fs-4">Otomasyon paneline hoş geldiniz. Sol menüyü kullanarak kitap, üye ve ödünç alma/iade işlemlerini kolayca yönetebilirsiniz.</p>
        </div>
    </div>

    <div class="row text-center">
        <div class="col-md-4 mb-3">
            <div class="card border-primary h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-primary">Toplam Kitap Sayısı</h5>
                    <h2 class="display-4 fw-bold">@totalBooks</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-success">Kayıtlı Üye Sayısı</h5>
                    <h2 class="display-4 fw-bold">@totalMembers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-warning h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-warning">Ödünçteki Kitaplar</h5>
                    <h2 class="display-4 fw-bold">@activeBorrowsCount</h2>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalBooks = 0;
    private int totalMembers = 0;
    private int activeBorrowsCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var books = await BookService.GetBooksAsync();
        totalBooks = books.Count;

        var members = await MemberService.GetMembersAsync();
        totalMembers = members.Count;

        var borrows = await BorrowService.GetActiveBorrowsAsync();
        activeBorrowsCount = borrows.Count;
    }
}