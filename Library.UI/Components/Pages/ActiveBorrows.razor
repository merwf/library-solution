@page "/active-borrows"
@using Library.Core
@using Library.UI.Services
@inject IBorrowService BorrowService
@inject IToastService Toast

<div class="container mt-4">
    <h3>Aktif Ödünç Kayıtları ve İade Yönetimi</h3>

    @if (penaltyResult != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <h5><strong>İade İşlemi Tamamlandı!</strong></h5>
            <p>Hesaplanan Ceza Durumu: <strong>@penaltyResult</strong></p>
            <button type="button" class="btn-close" @onclick="() => penaltyResult = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <span>Yükleniyor...</span>
        </div>
    }
    else if (loadError != null)
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>@loadError</span>
            <button class="btn btn-sm btn-outline-danger" @onclick="RefreshList">Tekrar Dene</button>
        </div>
    }
    else if (activeBorrows == null || !activeBorrows.Any())
    {
        <div class="alert alert-warning">Şu anda ödünçte olan hiç kitap bulunmamaktadır.</div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Kayıt ID</th>
                    <th>Kitap Adı</th>
                    <th>Üye Adı</th>
                    <th>Ödünç Tarihi</th>
                    <th>Son Teslim Tarihi</th>
                    <th>Ülke</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in activeBorrows)
                {
                    <tr>
                        <td>@record.Id</td>
                        <td>@record.BookTitle</td>
                        <td>@record.MemberName</td>
                        <td>@record.BorrowDate.ToString("dd.MM.yyyy")</td>
                        <td>@record.DueDate.ToString("dd.MM.yyyy")</td>
                        <td><span class="badge bg-secondary">@record.CountryCode</span></td>
                        <td>
                            <button class="btn btn-warning btn-sm" @onclick="() => HandleReturn(record.Id)" disabled="@(processingId == record.Id)">
                                @if (processingId == record.Id)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <text>İşleniyor...</text>
                                }
                                else
                                {
                                    <text>İade Al ve Ceza Hesapla</text>
                                }
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<BorrowRecordDto>? activeBorrows;
    private string? penaltyResult;
    private bool isLoading = true;
    private string? loadError;
    private int? processingId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshList();
    }

    private async Task RefreshList()
    {
        isLoading = true;
        loadError = null;
        try
        {
            activeBorrows = await BorrowService.GetActiveBorrowsAsync();
        }
        catch (Exception)
        {
            loadError = "Aktif ödünç kayıtları yüklenirken bir hata oluştu. Lütfen API bağlantısını kontrol edip tekrar deneyin.";
            activeBorrows = new List<BorrowRecordDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleReturn(int recordId)
    {
        penaltyResult = null;
        processingId = recordId;
        try
        {
            // API'ye iade isteği atıp backend'deki ceza hesaplayıcı sonucunu alıyoruz
            string result = await BorrowService.ReturnBookAsync(recordId);

            if (result.StartsWith("Hata"))
            {
                Toast.ShowError(result);
            }
            else
            {
                penaltyResult = result;
                Toast.ShowSuccess("Kitap başarıyla iade alındı.");
            }

            // Listeyi güncelliyoruz (İade edilen kitap listeden düşecek)
            await RefreshList();
        }
        catch (Exception)
        {
            Toast.ShowError("Sunucuya ulaşılamadı. İade işlemi gerçekleştirilemedi.");
        }
        finally
        {
            processingId = null;
        }
    }
}
