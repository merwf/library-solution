@page "/members"
@using Library.Core
@using Library.UI.Services
@inject IMemberService MemberService
@inject IToastService Toast

<div class="container mt-4">
    <!-- Üst Başlık ve Yeni Üye Ekleme Butonu -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h3>Üye Yönetim Paneli</h3>
        <button class="btn btn-dark" @onclick="() => showAddPanel = !showAddPanel">
            @(showAddPanel ? "Formu Kapat" : "Yeni Üye Ekle")
        </button>
    </div>

    <!-- Üye Ekleme Formu (Koyu Lacivert / Siyah Kurumsal Tema) -->
    @if (showAddPanel)
    {
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-dark text-white fw-bold py-3" style="background-color: #212529 !important;">
                <h5 class="mb-0">Yeni Üye Kayıt Formu</h5>
            </div>
            <div class="card-body border border-top-0 rounded-bottom">
                <EditForm Model="newMember" OnValidSubmit="HandleAddMember">
                    <DataAnnotationsValidator />
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Adı Soyadı</label>
                            <InputText class="form-control" @bind-Value="newMember.FullName" placeholder="Merve Gazioğlu" disabled="@isSubmitting" />
                            <ValidationMessage For="() => newMember.FullName" class="text-danger" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">E-Posta Adresi</label>
                            <InputText class="form-control" @bind-Value="newMember.Email" placeholder="ornek@kocaeli.edu.tr" disabled="@isSubmitting" />
                            <ValidationMessage For="() => newMember.Email" class="text-danger" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100" style="background-color: #0d6efd; border: none;" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <text>Kaydediliyor...</text>
                                }
                                else
                                {
                                    <text>Kaydet</text>
                                }
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <!-- Arama ve Filtreleme Paneli -->
    <div class="card mb-3 bg-light border">
        <div class="card-body row g-2">
            <div class="col-md-6">
                <input type="text" class="form-control" placeholder="Ad Soyad ile ara..." @bind="searchName" @bind:event="oninput" />
            </div>
            <div class="col-md-6">
                <input type="text" class="form-control" placeholder="E-Posta ile ara..." @bind="searchEmail" @bind:event="oninput" />
            </div>
        </div>
    </div>

    <!-- Üye Listesi Tablosu -->
    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <span>Yükleniyor...</span>
        </div>
    }
    else if (loadError != null)
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>@loadError</span>
            <button class="btn btn-sm btn-outline-danger" @onclick="RefreshList">Tekrar Dene</button>
        </div>
    }
    else if (members == null || !members.Any())
    {
        <div class="alert alert-secondary text-center">Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-bordered table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Adı Soyadı</th>
                        <th>E-Posta Adresi</th>
                        <th style="width: 150px;">Kayıt Tarihi</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!FilteredMembers.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-3">Aranan kriterlere uygun üye bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var member in FilteredMembers)
                        {
                            <tr>
                                <td>@member.Id</td>
                                <td class="fw-semibold">@member.FullName</td>
                                <td>@member.Email</td>
                                <td>@member.MembershipDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<MemberDto>? members;
    private MemberDto newMember = new();
    private bool showAddPanel = false;

    private string searchName = "";
    private string searchEmail = "";

    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshList();
    }

    private async Task RefreshList()
    {
        isLoading = true;
        loadError = null;
        try
        {
            members = await MemberService.GetMembersAsync();
        }
        catch (Exception)
        {
            loadError = "Üyeler yüklenirken bir hata oluştu. Lütfen API bağlantısını kontrol edip tekrar deneyin.";
            members = new List<MemberDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleAddMember()
    {
        isSubmitting = true;
        try
        {
            var success = await MemberService.AddMemberAsync(newMember);
            if (success)
            {
                Toast.ShowSuccess($"\"{newMember.FullName}\" üye olarak eklendi.");
                newMember = new();
                showAddPanel = false;
                await RefreshList();
            }
            else
            {
                Toast.ShowError("Üye eklenirken bir hata oluştu. Bilgileri kontrol edin.");
            }
        }
        catch (Exception)
        {
            Toast.ShowError("Sunucuya ulaşılamadı. Üye eklenemedi.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private IEnumerable<MemberDto> FilteredMembers
    {
        get
        {
            if (members == null) return Enumerable.Empty<MemberDto>();

            return members.Where(m =>
                (string.IsNullOrEmpty(searchName) || m.FullName.Contains(searchName, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrEmpty(searchEmail) || m.Email.Contains(searchEmail, StringComparison.OrdinalIgnoreCase))
            );
        }
    }
}
