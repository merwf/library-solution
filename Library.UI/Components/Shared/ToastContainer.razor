@implements IDisposable
@inject IToastService ToastService
@using Library.UI.Services

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @foreach (var toast in ToastService.Messages.ToList())
    {
        <div class="toast show align-items-center text-white @BgClass(toast.Type) border-0 mb-2" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @Icon(toast.Type) @toast.Text
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        aria-label="Kapat" @onclick="() => ToastService.Remove(toast.Id)"></button>
            </div>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnChange += Refresh;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private static string BgClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-success",
        ToastType.Error => "bg-danger",
        ToastType.Warning => "bg-warning",
        _ => "bg-info"
    };

    private static string Icon(ToastType type) => type switch
    {
        ToastType.Success => "✅",
        ToastType.Error => "⛔",
        ToastType.Warning => "⚠️",
        _ => "ℹ️"
    };

    public void Dispose()
    {
        ToastService.OnChange -= Refresh;
    }
}
